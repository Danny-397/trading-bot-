# ── Flask (optional) ───────────────────────────────────────────────────────
# Port to bind. Render sets this automatically — leave unset locally to use 5000.
PORT=5000

# ── Database (optional) ───────────────────────────────────────────────────
# Full path to the SQLite file. On Render with a persistent disk, use:
#   DATABASE_PATH=/data/tradebot.db
# Locally: leave unset — defaults to backend/tradebot.db
DATABASE_PATH=

# ── CORS (optional) ───────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# In production, set this to your Vercel URL to lock down API access:
#   CORS_ORIGINS=https://your-project.vercel.app
# Leave unset locally (defaults to * — all origins allowed).
CORS_ORIGINS=

# ── No brokerage API keys required ─────────────────────────────────────────
# TradeBot uses an internal paper-trading simulator that fills orders at real
# market prices from yfinance. No Alpaca (or any brokerage) account is needed.
